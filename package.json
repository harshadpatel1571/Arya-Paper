{
    "name": "faunaflora",
    "version": "1.0.0",
    "author": "",
    "homepage": "https://themewagon.github.io/FaunaFlora",
    "description": "",
    "scripts": {
        "predeploy": "npm run build",
        "deploy": "gh-pages -d .",
        "browsersync": "browser-sync start --directory --server . --files \"*.html, css/**/*, fauna-assets/**/*, images/**/*\" --startPath index.html",
        "clean": "rimraf about.html blog.html contact.html index.html login.html pricing.html register.html css fauna-assets images favicon.png robots.txt",
        "copy-assets": "cpx \"src/assets/**/*.*\" ./",
        "css-compile": "tailwindcss -i src/tailwind/tailwind.css -c src/tailwind/tailwind.config.js -o css/tailwind/tailwind.css",
        "css-minified": "tailwindcss -i src/tailwind/tailwind.css -c src/tailwind/tailwind.config.js -o css/tailwind/tailwind.min.css --minify",
        "css": "npm-run-all --sequential css-*",
        "templates": "pug --pretty -o ./ src/pug/",
        "build": "npm-run-all --sequential clean copy-* templates css",
        "watch": "npm-run-all build --parallel watch-templates watch-css browsersync",
        "watch-templates": "npm run templates -- --watch",
        "watch-css": "tailwindcss -i src/tailwind/tailwind.css -c src/tailwind/tailwind.config.js -o css/tailwind/tailwind.min.css --minify --watch"
    },
    "dependencies": {
        "tailwindcss": "^3.0.7"
    },
    "devDependencies": {
        "autoprefixer": "^10.4.0",
        "browser-sync": "^2.27.7",
        "cpx": "^1.5.0",
        "gh-pages": "^6.3.0",
        "npm-run-all": "^4.1.5",
        "pug": "^3.0.2",
        "pug-cli": "^1.0.0-alpha6",
        "rimraf": "^3.0.2"
    }
}